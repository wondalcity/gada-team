# ================================================================
# apps/web — Local Development Environment
# Copy to .env.local and fill in your values
# ================================================================

# API base URL — where the Spring Boot API is running
# Leave empty to use Next.js rewrites (default: http://localhost:8090)
NEXT_PUBLIC_API_URL=

# Firebase Configuration
# Get these from: https://console.firebase.google.com → Project Settings → Your Apps
# For local dev without Firebase: see docs/LOCAL_DEV.md for mock auth setup
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
