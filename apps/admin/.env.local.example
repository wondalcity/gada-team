# ================================================================
# apps/admin — Local Development Environment
# Copy to .env.local and fill in values
# ================================================================

# API base URL — where the Spring Boot API is running
# Used by Next.js rewrites: /api/* → NEXT_PUBLIC_API_URL/*
# Defaults to http://localhost:8090 if not set
NEXT_PUBLIC_API_URL=http://localhost:8090

# Admin token for localStorage injection (optional - set via UI login)
# NEXT_PUBLIC_DEV_ADMIN_TOKEN=
