# ═══════════════════════════════════════════════════════════════════
#  GADA Team — Production Environment Variables
#  Copy to Railway, Vercel, etc. as needed (never commit with secrets)
# ═══════════════════════════════════════════════════════════════════

# ── Spring Boot API (Railway) ──────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8090

# ── Database (Supabase) ────────────────────────────────────────────
# Use Transaction Pooler URL for normal queries (port 6543)
DB_URL=jdbc:postgresql://aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
DB_POOL_SIZE=5

# Use Session Mode URL for Flyway migrations (port 5432)
FLYWAY_DB_URL=jdbc:postgresql://aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ── Redis (Upstash) ───────────────────────────────────────────────
REDIS_HOST=YOUR_UPSTASH_REDIS_HOST
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_UPSTASH_REDIS_PASSWORD

# ── Firebase Admin SDK ────────────────────────────────────────────
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
# Service account JSON (single-line, escape newlines)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Toss Payments ─────────────────────────────────────────────────
TOSS_SECRET_KEY=YOUR_TOSS_SECRET_KEY

# ── AWS S3 ────────────────────────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=gada-hiring-media
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
CLOUDFRONT_DOMAIN=YOUR_CLOUDFRONT_DOMAIN

# ── Web App (Vercel) ──────────────────────────────────────────────
INTERNAL_API_URL=https://YOUR_RAILWAY_API_URL/api
NEXT_PUBLIC_API_URL=https://YOUR_RAILWAY_API_URL
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_TOSS_CLIENT_KEY=YOUR_TOSS_CLIENT_KEY

# ── Admin App (Vercel) ────────────────────────────────────────────
# (same Firebase + INTERNAL_API_URL as above)
